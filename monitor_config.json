{
  "project_id": "portable_monitor",
  "debounce_seconds": 2,
  "watch_patterns": [
    "*.py",
    "*.js",
    "*.jsx",
    "*.ts",
    "*.tsx",
    "*.java",
    "*.cpp",
    "*.c",
    "*.h",
    "*.cs",
    "*.php",
    "*.rb"
  ],
  "ignore_patterns": [
    "node_modules",
    ".git",
    "__pycache__",
    "*.pyc",
    "venv",
    "env",
    "dist",
    "build",
    ".next",
    ".cache",
    "portable_monitor.py",
    "monitor_config.json",
    "requirements.txt"
  ]
}